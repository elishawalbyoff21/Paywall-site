# .env.local — Copy this to .env.local and fill in your values. NEVER commit this file.

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get this from https://dashboard.stripe.com/webhooks after creating your webhook endpoint
# Endpoint URL: https://yourdomain.com/api/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # Service role key (NOT the anon key — keep secret)

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://yourdomain.com  # No trailing slash

# ── Admin ──────────────────────────────────────────────────────────────────────
# Choose a strong password for your admin dashboard
ADMIN_PASSWORD=choose-a-very-strong-password-here
